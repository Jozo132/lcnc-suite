# Supply-chain hardening (2026 npm worms: Miasma / IronWorm / Shai-Hulud).
# These worms detonate during `npm install`/`npm ci` via dependency lifecycle
# hooks (pre/post/install) and the implicit node-gyp `binding.gyp` build path.
# Disabling auto-run scripts removes that entire attack surface.
#
# Safe for this project: the ONLY package here with an install hook is esbuild,
# and its native binary ships as the @esbuild/<platform> package file (not built
# by the hook), so the build keeps working with scripts off.
#
# To intentionally run a package's install script later:
#   npm install <pkg> --ignore-scripts=false   # one-off
#   npm rebuild <pkg>                           # re-run an installed pkg's build
ignore-scripts=true
