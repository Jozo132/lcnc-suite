%
o<on_abort> sub
; Re-enable overrides (probing routines disable them with M50/M51 P0)
M50 P1    (re-enable feed override)
M51 P1    (re-enable spindle override)
; Safe modal state
G90       (absolute mode)
G40       (cancel cutter comp)
G49       (cancel tool length comp)
G80       (cancel canned cycles)
o<on_abort> endsub
%
